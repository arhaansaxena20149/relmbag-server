{
	"name": "create-dmg",
	"version": "8.1.0",
	"description": "Create a good-looking DMG for your macOS app in seconds",
	"license": "MIT",
	"repository": "sindresorhus/create-dmg",
	"funding": "https://github.com/sponsors/sindresorhus",
	"author": {
		"name": "Sindre Sorhus",
		"email": "sindresorhus@gmail.com",
		"url": "https://sindresorhus.com"
	},
	"type": "module",
	"bin": {
		"create-dmg": "./cli.js"
	},
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"test": "ava",
		"build": "cd ComposeIcon && xcrun swift build -c release --arch arm64 --arch x86_64 --product compose-icon && cp .build/apple/Products/Release/compose-icon ../compose-icon",
		"prepublishOnly": "npm run build"
	},
	"files": [
		"cli.js",
		"compose-icon.js",
		"sla.js",
		"assets",
		"disk-icon.icns",
		"compose-icon"
	],
	"keywords": [
		"cli-app",
		"cli",
		"create",
		"dmg",
		"disk",
		"image",
		"macos",
		"mac",
		"app",
		"application",
		"apple"
	],
	"dependencies": {
		"appdmg": "^0.6.6",
		"execa": "^9.6.1",
		"icns-lib": "^1.0.1",
		"meow": "^14.0.0",
		"ora": "^9.1.0",
		"plist": "^3.1.0",
		"tempy": "^3.1.1"
	},
	"devDependencies": {
		"ava": "^6.4.1",
		"jest-image-snapshot": "^6.5.1",
		"xo": "^1.2.3"
	},
	"ava": {
		"serial": true,
		"timeout": "30s"
	}
}
